# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# MinIO (S3互換ローカルストレージ)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bedrock Knowledge Bases
# ローカル開発では false のままにする。
# AWS デプロイ時は true に変更し、KB ID と Data Source ID を設定する。
BEDROCK_KB_ENABLED=false
BEDROCK_KB_ID=
BEDROCK_KB_DATA_SOURCE_ID=

# Bedrock 認証情報（ローカル開発専用）
# docker-compose では AWS_ACCESS_KEY_ID が MinIO 用に上書きされるため、Bedrock 用に別途設定する。
# AWS デプロイ時は IAM タスクロールで解決されるため、これらは不要（設定しない）。
BEDROCK_AWS_ACCESS_KEY_ID=
BEDROCK_AWS_SECRET_ACCESS_KEY=

# Bedrock モデルID（変更する場合のみ設定）
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
